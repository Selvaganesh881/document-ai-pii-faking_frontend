# =========================
# Project Specific (Crucial!)
# =========================
# Do not copy local uploaded PDFs into the container
backend/uploads/*
!backend/uploads/.gitkeep

# Do not copy the local SQLite database into the image
backend/data/*
!backend/data/.gitkeep

# Ignore local environment variables (Docker Compose handles this)
.env